// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Test {
  id    String @id @default(cuid())
  Title String
}

model User {
  id                     String              @id
  name                   String
  email                  String
  emailVerified          Boolean             @default(false)
  image                  String?
  plan                   String              @default("free") //free | pro
  aiCredits              Int                 @default(50)
  razorpaySubscriptionId String?
  subscriptionStatus     String? //active | cancelled | trailing
  subscriptionRenewsAt   DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  sessions               Session[]
  accounts               Account[]
  githubInstallation     GithubInstallation?
  workspaces             Workspace[]

  @@unique([email])
  @@map("user")
}

model GithubInstallation {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  installationId Int // GitHub's numeric installation id — passed to app.getInstallationOctokit()
  accountLogin   String?
  accountType    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("github_installation")
}

model PullRequest {
  id             String    @id @default(cuid())
  installationId Int
  repoFullName   String // e.g. "owner/repo"
  prNumber       Int
  title          String
  authorLogin    String?
  headSha        String // latest commit on the PR branch
  baseBranch     String
  status         String    @default("pending") // pending | processing | reviewed | rate_limited
  reviewComment  String? // AI-generated markdown saved after review completes
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  featureRequestId String?
  featureRequest   FeatureRequest? @relation(fields: [featureRequestId], references: [id], onDelete: SetNull)

  @@unique([repoFullName, prNumber])
  @@index([featureRequestId])
  @@map("pull_request")
}

model RepoSync {
  id             String    @id @default(cuid())
  installationId Int
  repoFullName   String
  branch         String
  status         String    @default("pending") // pending | syncing | synced | failed
  chunkCount     Int       @default(0)
  syncedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([repoFullName])
  @@map("repo_sync")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Workspace {
  id        String    @id @default(cuid())
  name      String
  slug      String?    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])

  @@map("workspace")
}

model Project {
  id              String           @id @default(cuid())
  name            String
  description     String?
  githubRepoUrl   String?
  githubRepoName  String?
  workspaceId     String
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  featureRequests FeatureRequest[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([workspaceId])
  @@map("project")
}

model FeatureRequest {
  id          String   @id @default(cuid())
  title       String
  description String
  status      String   @default("pending_analysis") // pending_analysis | clarifying | drafting_prd | approved | in_progress | completed
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  prd         PRD?
  messages    Message[]
  tasks       Task[]
  pullRequests PullRequest[]
  releaseHistories ReleaseHistory[]
  source      String   @default("MANUAL") //EMAIL | TICKET | CALL | MANUAL | AGENT
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@map("feature_request")
}

model Message {
  id               String         @id @default(cuid())
  featureRequestId String
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  role             String         // "user" | "assistant"
  content          String
  createdAt        DateTime       @default(now())

  @@index([featureRequestId])
  @@map("message")
}

model PRD {
  id               String         @id @default(cuid())
  featureRequestId String         @unique
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  problemStatement   String
  edgeCases String
  goals String[]
  nonGoals String[]
  userStories String[]
  successMetrics String[]
  acceptanceCriteria String[]
  implementationApproach String[]
  content          String         // Markdown content
  status           String         @default("draft") // draft | approved
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("prd")
}

model Task {
  id               String         @id @default(cuid())
  title            String
  description      String?
  status           String         @default("TODO") // TODO | IN_PROGRESS | DONE
  featureRequestId String
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  order            Int            @default(0) // For Kanban ordering
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([featureRequestId])
  @@map("task")
}

model ReleaseHistory {
  id                  String         @id @default(cuid())
  featureRequestId    String
  featureRequest      FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  prNumber            Int
  commitSha           String
  mergedBy            String
  completionPercentage Int
  verificationResult  String?        // Store status like READY_FOR_MERGE
  releaseNotes        String?
  releasedAt          DateTime       @default(now())

  @@index([featureRequestId])
  @@map("release_history")
}
